# Copy this file to ".env" (same folder) and fill in your own values.
# Find both of these in your Supabase project: Settings → API.
#
# The anon key is designed to be public — it's safe to ship in your built
# JS bundle. Access control is enforced by the Row Level Security policies
# in supabase/schema.sql, not by keeping this key secret.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
